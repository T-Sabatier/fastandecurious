{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],

      "$code": {
        ".write": "auth != null && $code.matches(/^[A-HJ-NP-Z2-9]{4}$/)",
        ".validate": "newData.hasChildren(['createdAt', 'host', 'players', 'phase'])",

        "createdAt": { ".validate": "newData.isNumber()" },
        "host": { ".validate": "newData.isString()" },
        "phase": { ".validate": "newData.isString()" },

        "players": {
          "$playerId": {
            "name": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "score": { ".validate": "newData.isNumber()" }
          }
        }
      }
    },

    "cards": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admin').child(auth.uid).exists()",
      "$cardId": {
        "t": { ".validate": "newData.isString() && newData.val().length <= 80" },
        "cat": { ".validate": "newData.isString() && newData.val().length <= 40" }
      }
    },

    "categories": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admin').child(auth.uid).exists()"
    },

    "deletedDefaults": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admin').child(auth.uid).exists()"
    },

    "deletedCategories": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admin').child(auth.uid).exists()"
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },

    "stats": {
      ".read": "auth != null && root.child('admin').child(auth.uid).exists()",
      "$stat": {
        ".write": "auth != null",
        ".validate": "newData.isNumber() && (!data.exists() || newData.val() >= data.val())"
      }
    },

    "admin": {
      ".read": false,
      ".write": false
    }
  }
}
