# Copie ce fichier en .env et remplis avec les clés de ton projet Firebase
# Tu trouveras ces valeurs dans Firebase Console → Paramètres du projet → Tes applications → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# L'acces /admin passe desormais par Firebase Auth (email/mot de passe).
# Voir SECURITE.md pour creer le compte admin — plus de code en variable d'env.

# App Check (web) : cle PUBLIQUE du site reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
# Vide = App Check desactive (aucun effet). Voir SECURITE.md section App Check.
VITE_RECAPTCHA_V3_SITE_KEY=
