# Copie ce fichier en .env et remplis avec les clés de ton projet Firebase
# Tu trouveras ces valeurs dans Firebase Console → Paramètres du projet → Tes applications → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# L'acces /admin passe desormais par Firebase Auth (email/mot de passe).
# Voir SECURITE.md pour creer le compte admin — plus de code en variable d'env.
